# Copy to functions/.env for local emulator (do not commit .env).

# HubSpot private app token — scopes: crm.objects.contacts.read/write,
# crm.objects.custom.read/write (or your DM Customer Feedback object scopes).
# For automatic primary display + required fields on create, also add: crm.schemas.custom.read
HUBSPOT_ACCESS_TOKEN=

# Custom object: label "DM Customer Feedback", internal name "customer_feedback" (HubSpot uses this in API errors).
# This env value must be the object TYPE ID (numeric id like 2-12345678 from object settings / CRM API), not the string "customer_feedback".
# Example format: 2-12345678
HUBSPOT_DM_CUSTOMER_FEEDBACK_OBJECT_TYPE_ID=

# Primary display property internal name on the DM Customer Feedback object (default: name).
# HubSpot requires this on create. If your object uses a different record title property, set it here.
# HUBSPOT_DM_CF_DISPLAY_NAME_PROPERTY=name

# When creating a new survey record (no survey_record_id in URL), associate to Contact.
# Find the association type ID in HubSpot (Settings → Associations) for Contact ↔ DM Customer Feedback.
# HUBSPOT_DM_CF_CONTACT_ASSOCIATION_TYPE_ID=

# If association uses USER_DEFINED instead of HUBSPOT_DEFINED (portal-specific).
# HUBSPOT_DM_CF_CONTACT_ASSOCIATION_CATEGORY=HUBSPOT_DEFINED

# Optional metadata sent on DM Customer Feedback records
# SURVEY_VERSION=v1
# SURVEY_SOURCE_SYSTEM=testimonial_lp

# Comma-separated emails allowed to use /admin (Google sign-in must match).
ADMIN_EMAIL_ALLOWLIST=you@company.com
