{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "hosting": {
      "port": 5050
    },
    "functions": {
      "port": 5010
    },
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": true,
      "port": 4040
    }
  },
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/submit-survey", "function": "submitSurvey" },
      { "source": "/api/survey-config", "function": "getSurveyConfig" },
      { "source": "/api/admin/survey-templates", "function": "adminSurveyTemplates" },
      { "source": "/admin", "destination": "/admin/index.html" },
      { "source": "/admin/", "destination": "/admin/index.html" },
      { "source": "/service", "destination": "/survey.html" },
      { "source": "/service/**", "destination": "/survey.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
